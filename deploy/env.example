DJANGO_SECRET_KEY=replace-with-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=invoices.rajatht.me,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://invoices.rajatht.me
# Optional: correct calendar “today” for AU (date max / delivery days)
# DJANGO_TIME_ZONE=Australia/Sydney

# If PDF conversion fails: full path to soffice (e.g. /Applications/LibreOffice.app/Contents/MacOS/soffice)
# INVOICE_SOFFICE=
# Seconds before LibreOffice convert is killed (default 180)
# INVOICE_LIBREOFFICE_TIMEOUT=180

# Optional logo (openpyxl re-embeds). Place invoice_branding.png in assets/invoice/
# INVOICE_LOGO_ANCHOR=A1
# INVOICE_LOGO_WIDTH_PX=200
# INVOICE_LOGO_HEIGHT_PX=80

# Email (optional). Default: console backend (prints in journal / terminal only).
# For real delivery set SMTP and:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=invoices@rajatht.me
